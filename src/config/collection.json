{
  "version": "1.1.0",
  "bestiary": [
    { "id": "snake", "category": "enemy", "label": "小蛇", "element": "wood", "lore": "木氣所化，遊走於草莽之間，性敏而體弱。", "spriteType": "snake" },
    { "id": "fly", "category": "enemy", "label": "小蒼蠅", "element": "metal", "lore": "金氣凝形，振翅疾行，雖渺小卻不可輕忽。", "spriteType": "fly" },
    { "id": "salamander", "category": "enemy", "label": "火蜥蜴", "element": "fire", "lore": "火氣所孕，吐焰而行，灼熱難當。", "spriteType": "salamander" },
    { "id": "water_spirit", "category": "enemy", "label": "水靈", "element": "water", "lore": "水氣化靈，流轉無常，以柔克剛。", "spriteType": "water_spirit" },
    { "id": "golem", "category": "enemy", "label": "石傀儡", "element": "earth", "lore": "厚土凝形，步步沉重，非烈火不能破其堅。", "spriteType": "golem" },
    { "id": "beetle", "category": "enemy", "label": "金甲蟲", "element": "metal", "lore": "金氣附甲，堅不可摧，緩步前行如鐵壁。", "spriteType": "beetle" },
    { "id": "boss_dragon", "category": "enemy", "label": "龍影", "element": "fire", "lore": "火之精魄，每五劫一現。翼展遮天，非五行合力不能制。", "spriteType": "boss_dragon" },
    { "id": "fire", "category": "tower", "label": "烈焰塔", "element": "fire", "lore": "火行陣器，焚盡來犯之敵。烈焰所至，寸草不生。", "spriteType": "fire" },
    { "id": "water", "category": "tower", "label": "冰凍塔", "element": "water", "lore": "水行陣器，寒氣逼人，凍結萬物於無形。", "spriteType": "water" },
    { "id": "wood", "category": "tower", "label": "纏繞塔", "element": "wood", "lore": "木行陣器，藤蔓纏身，困敵於步步荊棘。", "spriteType": "wood" },
    { "id": "earth", "category": "tower", "label": "岩壁塔", "element": "earth", "lore": "土行陣器，厚實如山，築牆引路以困妖邪。", "spriteType": "earth" },
    { "id": "metal", "category": "tower", "label": "鏡刃塔", "element": "metal", "lore": "金行陣器，鋒芒畢露，斬妖除魔如破竹。", "spriteType": "metal" },
    { "id": "yin", "category": "tower", "label": "暗影塔", "element": "yin", "lore": "陰儀之器，藏影於暗，以幽深之力侵蝕敵魂。", "spriteType": "yin" },
    { "id": "yang", "category": "tower", "label": "聖光塔", "element": "yang", "lore": "陽儀之器，光明普照，以浩然之氣驅散邪祟。", "spriteType": "yang" },
    { "id": "fire_2", "category": "tower", "label": "熾天塔", "element": "fire", "level": 2, "lore": "雙重火行陣器，焰分兩儀。內焰灼心，外焰焚野，二火合一則天地為爐。", "spriteType": "fire_2" },
    { "id": "water_2", "category": "tower", "label": "霜淵塔", "element": "water", "level": 2, "lore": "雙冰疊陣，寒氣疊加。凍結之勢如深淵降臨，萬物凝滯。", "spriteType": "water_2" },
    { "id": "wood_2", "category": "tower", "label": "荊棘塔", "element": "wood", "level": 2, "lore": "雙木成林，藤蔓交織。荊棘叢生如迷宮，困敵於步步難行。", "spriteType": "wood_2" },
    { "id": "earth_2", "category": "tower", "label": "磐石塔", "element": "earth", "level": 2, "lore": "疊土為城，厚實如山。雙壁合攏，妖邪無隙可趁。", "spriteType": "earth_2" },
    { "id": "metal_2", "category": "tower", "label": "雙刃塔", "element": "metal", "level": 2, "lore": "雙金交鋒，刃光如電。斬妖除魔更勝單鋒之利。", "spriteType": "metal_2" },
    { "id": "yin_2", "category": "tower", "label": "幽影塔", "element": "yin", "level": 2, "lore": "雙陰疊影，暗湧流深。幽暗之力倍增，侵蝕神魂於無聲。", "spriteType": "yin_2" },
    { "id": "yang_2", "category": "tower", "label": "輝光塔", "element": "yang", "level": 2, "lore": "雙陽交輝，光明大放。浩然正氣如日中天，邪祟無所遁形。", "spriteType": "yang_2" },
    { "id": "wood_fire", "category": "tower", "label": "焚林塔", "element": "wood", "level": 2, "recipe": true, "lore": "木火相生，燒天焚地。烈焰燃林後勁綿長，灼燒不絕。", "spriteType": "wood_fire" },
    { "id": "fire_earth", "category": "tower", "label": "熔岩塔", "element": "fire", "level": 2, "recipe": true, "lore": "火土相交，熔岩湧地。熾熱岩漿持傷不退，焦土千里。", "spriteType": "fire_earth" },
    { "id": "earth_metal", "category": "tower", "label": "鍛造塔", "element": "earth", "level": 2, "recipe": true, "lore": "土金相濟，百煉成鋼。增益之陣強化友軍，眾塔齊鳴。", "spriteType": "earth_metal" },
    { "id": "metal_water", "category": "tower", "label": "寒鐵塔", "element": "metal", "level": 2, "recipe": true, "lore": "金水相生，冷冽徹骨。寒鐵之鋒遲敵裂甲，一擊雙效。", "spriteType": "metal_water" },
    { "id": "water_wood", "category": "tower", "label": "靈木塔", "element": "water", "level": 2, "recipe": true, "lore": "水木相涵，生機湧現。靈木盤根化為臨時壁壘，扭轉戰局。", "spriteType": "water_wood" },
    { "id": "yin_yang", "category": "tower", "label": "太極塔", "element": "taiji", "level": 2, "recipe": true, "lore": "陰陽交泰，太極化生。此器融暗明二氣，以無極之勢吞吐乾坤。", "spriteType": "yin_yang" },
    { "id": "trait_armor", "category": "trait", "label": "鐵壁", "element": "all", "lore": "鐵壁之護，臨危不懼。怪得此詞，減傷三成，如披重甲。", "spriteType": "trait_armor" },
    { "id": "trait_regen", "category": "trait", "label": "再生", "element": "all", "lore": "生生不息，斷肢重生。怪得此詞，徐徐回血，持久難纏。", "spriteType": "trait_regen" },
    { "id": "trait_split", "category": "trait", "label": "分裂", "element": "all", "lore": "一分為二，二化為四。怪得此詞，臨死分身，防不勝防。", "spriteType": "trait_split" }
  ],
